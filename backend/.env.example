# Copie para .env e ajuste os valores
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-segura-de-64-caracteres
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
DATABASE_URL=postgresql://escalas:escalas@db:5432/escalas
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# E-mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=sua-senha-de-app
EMAIL_FROM=noreply@suaempresa.com
EMAIL_FROM_NAME=Sistema de Escalas

# Primeiro gestor (seed)
FIRST_MANAGER_EMAIL=admin@suaempresa.com
FIRST_MANAGER_PASSWORD=senha-segura-aqui
FIRST_MANAGER_NAME=Administrador

# Solver
SOLVER_RANDOM_SEED=42
SOLVER_MAX_TIME_SECONDS=60
